# Database Configuration
# Get this from Supabase connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://user:password@localhost:5432/vitrii"

# Node Environment
NODE_ENV="development"

# API Configuration
API_BASE_URL="http://localhost:5173"

# Auth Configuration
# Secret used to sign login session tokens (JWT). Required in production - generate
# a long random value, e.g. `openssl rand -hex 32`. Never reuse this across environments.
JWT_SECRET="change-me-to-a-long-random-value"

# Comma-separated list of origins allowed to call this API in production
# (falls back to APP_URL below if unset). Ignored in development.
ALLOWED_ORIGINS="https://www.vitrii.com.br,https://app.vitrii.com.br"

# Mercado Pago Configuration (for Pix payments)
# Get these from your Mercado Pago developer account
# https://www.mercadopago.com.br/developers
MERCADO_PAGO_ACCESS_TOKEN="your_access_token_here"
MERCADO_PAGO_PUBLIC_KEY="your_public_key_here"

# Payment Configuration
PAYMENT_PROVIDER="mercado-pago" # Options: mercado-pago, stripe
# Used to verify the `x-webhook-signature` header (HMAC-SHA256 of the raw request
# body) on incoming /api/webhooks/pagamentos calls. Without this set, the webhook
# rejects every request - required before wiring up a real payment provider.
PAYMENT_WEBHOOK_SECRET="your_webhook_secret_here"

# Ad Pricing Configuration
FREE_ADS_LIMIT=3 # Number of free ads per user
AD_COST=9.90 # Cost per ad after free limit

# Email Configuration (for password reset and notifications)
# For development: Leave these empty to use Ethereal test service
# For production: Configure with your SMTP provider

# APP_URL is used in password reset emails to generate the reset link
APP_URL="http://localhost:5173"

# SMTP Configuration (optional for production)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-specific-password"
# MAIL_FROM="noreply@vitrii.com"

# For Gmail, use App Passwords: https://support.google.com/accounts/answer/185833
